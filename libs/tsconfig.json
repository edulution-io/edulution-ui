{
  "extends": "../tsconfig.base.json",
  "compilerOptions": {
    "module": "ES2022",
    "moduleResolution": "Bundler",
    "declaration": true,
    "composite": true,
    "jsx": "react-jsx",
    "types": ["node", "vitest/globals"],
    "noPropertyAccessFromIndexSignature": true
  },
  "include": ["src/**/*.ts", "src/**/*.tsx"]
}
