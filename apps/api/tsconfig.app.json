{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "outDir": "../../dist/apps/api",
    "resolveJsonModule": true,
    "emitDecoratorMetadata": true,
    "target": "ES2022",
    "composite": true,
    "declaration": true
  },
  "exclude": [
    "src/**/*.spec.ts",
    "src/**/*.test.ts",
    "../../libs/src/**/*.spec.ts",
    "../../libs/src/**/*.spec.tsx",
    "../../libs/src/**/*.test.ts",
    "../../libs/src/**/*.test.tsx",
    "../../libs/src/test-utils/**/*",
    "../../libs/ui-kit/**/*"
  ],
  "include": ["./**/*", "../../libs/src/**/*", "../../package.json"]
}
